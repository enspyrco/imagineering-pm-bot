# EditorConfig — https://editorconfig.org
root = true

[*]
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.dart]
indent_style = space
indent_size = 2

[*.{json,yaml,yml,md}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile]
indent_style = space
indent_size = 4
